# =============================================================================
# AutoResearch Council Arena — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
#   cp .env.example .env
# =============================================================================


# --- Required ---

# Your OpenRouter API key.
# Get one at https://openrouter.ai/keys
# All council models and the chairman are accessed through this single key.
OPENROUTER_API_KEY=your_key_here


# --- Optional ---

# Maximum USD to spend before the experiment loop stops automatically.
# The loop checks cumulative spend via the OpenRouter API before each iteration.
#
# Examples:
#   COST_LIMIT_USD=0.10   — ~5 iterations, good for a quick test
#   COST_LIMIT_USD=1.00   — ~60 iterations, short exploratory run
#   COST_LIMIT_USD=5.00   — ~260 iterations, solid overnight run (default)
#   COST_LIMIT_USD=50.00  — ~2600 iterations, extended research run
#
# Remove or leave blank to run indefinitely (stop manually with Ctrl+C).
COST_LIMIT_USD=5.00
